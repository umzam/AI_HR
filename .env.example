# 复制本文件为 .env，填入你的火山引擎 API 配置
# 获取地址：https://console.volcengine.com/ark

# API Key（火山引擎方舟平台 → API Key 管理）
ARK_API_KEY=your-api-key-here

# 模型 ID（在方舟平台「模型推理」→「在线推理」→ 创建推理接入点后获得）
# 格式通常是 ep-xxxxxxxxxxxxxxxx-xxxxx 或直接使用模型名如 doubao-pro-32k
ARK_MODEL=ep-xxxxxxxxxxxxxxxx-xxxxx

# 火山引擎方舟 API 地址（固定，无需修改）
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
